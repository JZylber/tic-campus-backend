// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum OfferingKind {
  MANDATORY
  OPTIONAL
}

// Define your database models here

model User {
  id              Int               @id @default(autoincrement())
  dni             String            @unique
  email           String            @unique
  name            String?
  surname         String?
  googleId        String?           @unique
  jwtSecureCode   String?
  role            Role              @default(STUDENT)
  studentCourses  StudentCourse[]
  redos           RevisionRequest[]
  teacherOfferings TeacherOffering[]
}

model StudentCourse {
  id        Int    @id @default(autoincrement())
  student   User   @relation(fields: [studentId], references: [id])
  studentId Int
  courseId  Int
  course    Course @relation(fields: [courseId], references: [id])
  studentOfferings StudentOffering[]

  @@unique([studentId, courseId])
}

model Course {
  id        Int             @id @default(autoincrement())
  name      String
  specialty String
  year      Int
  students  StudentCourse[]
  offeringCourses  OfferingCourse[]
  revisionRequests RevisionRequest[]

  @@unique([name, year])
}

model RevisionRequest {
  id         Int      @id @default(autoincrement())
  student    User     @relation(fields: [studentId], references: [id])
  studentId  Int
  offering   Offering @relation(fields: [offeringId], references: [id])
  offeringId Int
  course     Course   @relation(fields: [courseId], references: [id])
  courseId   Int
  activityId String
  reason     String
  bonusTasks String?
  comment    String?
  date       DateTime
  reviewed   Boolean  @default(false)
}

// ---------------------------------------------------------------------------
// Refactor model: abstract Subject + Offering + M2M OfferingCourse + enrollment.
// The abstract subject (name/marks) is separate from its concrete Offering
// (spreadsheet/template/course). Membership: MANDATORY is derived via the
// `enrollment` SQL view; OPTIONAL is stored in StudentOffering (composite-FK gated).
// ---------------------------------------------------------------------------

model Subject {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  specialty String?
  marks     Boolean    @default(false)
  offerings Offering[]
}

model Offering {
  id            Int          @id @default(autoincrement())
  subject       Subject      @relation(fields: [subjectId], references: [id])
  subjectId     Int
  templateId    String
  spreadsheetId String?
  kind          OfferingKind @default(MANDATORY)
  year          Int
  offeringCourses  OfferingCourse[]
  teacherOfferings TeacherOffering[]
  redos            RevisionRequest[]
}

model OfferingCourse {
  id              Int      @id @default(autoincrement())
  offering        Offering @relation(fields: [offeringId], references: [id])
  offeringId      Int
  course          Course   @relation(fields: [courseId], references: [id])
  courseId        Int
  studentOfferings StudentOffering[]

  @@unique([offeringId, courseId])
}

model TeacherOffering {
  id         Int      @id @default(autoincrement())
  teacher    User     @relation(fields: [teacherId], references: [id])
  teacherId  Int
  offering   Offering @relation(fields: [offeringId], references: [id])
  offeringId Int

  @@unique([teacherId, offeringId])
}

// Enrollment for OPTIONAL offerings (MANDATORY membership is derived via the
// `enrollment` SQL view). The two composite FKs make an enrollment impossible
// unless the student is really in that course AND the offering serves it.
model StudentOffering {
  id          Int            @id @default(autoincrement())
  studentId   Int
  courseId    Int
  offeringId  Int
  enrolledVia StudentCourse  @relation(fields: [studentId, courseId], references: [studentId, courseId])
  eligible    OfferingCourse @relation(fields: [offeringId, courseId], references: [offeringId, courseId])

  @@unique([studentId, offeringId])
}
